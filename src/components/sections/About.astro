---
import type { Lang } from "../../i18n/utils";
import { useTranslations, highlightBrand } from "../../i18n/utils";

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="about" class="about" aria-labelledby="about-title">
  <div class="circle-deco about-circle-1" aria-hidden="true"></div>
  <div class="circle-deco circle-delay circle-fill about-circle-2" aria-hidden="true"></div>
  <div class="container">
    <p class="eyebrow reveal">Depuis 2024 à Douala</p>
    <h2 id="about-title" class="reveal">{t.about.title}</h2>

    <div class="about-content">
      <div class="about-text reveal">
        <p set:html={highlightBrand(t.about.intro)} />
        <blockquote class="about-quote" set:html={highlightBrand(t.about.intro2)} />

        <ul class="about-stats">
          {t.hero.metrics.slice(0, 3).map((m: any) => (
            <li>
              <strong>{m.value}</strong>
              <span>{m.label}</span>
            </li>
          ))}
        </ul>
      </div>
      <figure class="about-photo reveal">
        <img src="/images/about/team-photo.webp" alt={t.about.teamImageAlt} width="480" height="360" loading="lazy" />
        <span class="about-photo-badge">2024 — Douala 🇨🇲</span>
      </figure>
    </div>

    <div class="about-pillars">
      <article class="reveal"><span class="pillar-label">{t.about.mission.title}</span><p>{t.about.mission.text}</p></article>
      <article class="reveal"><span class="pillar-label">{t.about.visionMid.title}</span><p>{t.about.visionMid.text}</p></article>
      <article class="reveal"><span class="pillar-label">{t.about.visionLong.title}</span><p>{t.about.visionLong.text}</p></article>
    </div>

    <h3 class="values-title reveal">{t.about.valuesTitle}</h3>
    <ul class="values-grid">
      {t.about.values.map((v: any, i: number) => (
        <li class="value-item reveal">
          <span class="value-num">{String(i + 1).padStart(2, "0")}</span>
          <h4>{v.title}</h4>
          <p>{v.text}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .about { position: relative; overflow: hidden; }
  .about-circle-1 { top: -60px; right: 8%; width: 200px; height: 200px; }
  .about-circle-2 { bottom: 10%; left: -70px; width: 260px; height: 260px; }
  .about .container { position: relative; z-index: 1; }

  .about-content { display: grid; grid-template-columns: 1.3fr 1fr; gap: 3.5rem; align-items: center; margin-bottom: 3.5rem; }
  .about-text p { font-size: 1.05rem; }
  .about-text p + p { margin-top: 1rem; }

  .about-quote {
    margin: 1.5rem 0 0;
    padding-left: 1.25rem;
    border-left: 3px solid var(--color-accent);
    font-style: italic;
    color: var(--color-text-secondary);
  }

  .about-stats { display: flex; gap: 2rem; list-style: none; margin: 2rem 0 0; padding-top: 1.5rem; border-top: 1px solid var(--color-border); }
  .about-stats strong { display: block; font-size: 1.9rem; font-weight: 800; color: var(--color-accent); }
  .about-stats span { color: var(--color-text-secondary); font-size: 0.85rem; }

  .about-photo { position: relative; margin: 0; }
  .about-photo img {
    border-radius: 10px;
    width: 100%;
    display: block;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    transform: rotate(-1.5deg);
    box-shadow: 0 24px 48px rgba(2, 33, 121, 0.18);
    transition: transform 0.35s ease;
  }
  .about-photo:hover img { transform: rotate(0deg) scale(1.02); }
  .about-photo-badge {
    position: absolute;
    bottom: -16px;
    left: -16px;
    background: var(--color-accent);
    color: #fff;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.5rem 1rem;
    border-radius: 999px;
    box-shadow: 0 10px 20px rgba(2, 33, 121, 0.25);
  }

  .about-pillars { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 4rem; }
  .about-pillars article {
    padding: 1.75rem 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }
  .about-pillars article:hover {
    transform: translateY(-6px);
    box-shadow: 0 18px 32px rgba(2, 33, 121, 0.1);
    border-color: var(--color-accent);
  }
  .pillar-label { display: block; font-size: 1.1rem; margin-bottom: 0.5rem; color: var(--color-accent); }

  .values-title { margin-bottom: 1.5rem; }
  .values-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; list-style: none; }
  .value-item {
    padding: 1.75rem 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }
  .value-item:hover {
    transform: translateY(-6px);
    box-shadow: 0 18px 32px rgba(2, 33, 121, 0.1);
    border-color: var(--color-accent);
  }
  .value-num { color: var(--color-text-secondary); font-size: 0.9rem; opacity: 0.6; }
  .value-item h4 { margin: 0.5rem 0 0.4rem; }

  /* staggered entrance */
  .about-pillars article:nth-child(2) { transition-delay: 0.08s; }
  .about-pillars article:nth-child(3) { transition-delay: 0.16s; }
  .value-item:nth-child(2) { transition-delay: 0.06s; }
  .value-item:nth-child(3) { transition-delay: 0.12s; }
  .value-item:nth-child(4) { transition-delay: 0.18s; }

  @media (max-width: 900px) {
    .about-content { grid-template-columns: 1fr; }
    .about-photo { order: -1; }
    .about-pillars, .values-grid { grid-template-columns: 1fr; }
    .about-stats { flex-wrap: wrap; gap: 1.5rem; }
  }
</style>

<script is:inline src="/scripts/counter.js"></script>
