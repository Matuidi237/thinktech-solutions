---
import type { Lang } from "../../i18n/utils";
import { useTranslations } from "../../i18n/utils";

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

const icons: Record<string, string> = {
  rocket:
    '<path d="M12 2c2.5 2 4 5.5 4 9 0 2-1 4-2 5l-2 2-2-2c-1-1-2-3-2-5 0-3.5 1.5-7 4-9Z"/><circle cx="12" cy="10" r="1.6"/><path d="M9 16l-2.5 1.5L7 14"/><path d="M15 16l2.5 1.5L17 14"/>',
  server:
    '<rect x="3.5" y="4" width="17" height="6" rx="1.5"/><rect x="3.5" y="14" width="17" height="6" rx="1.5"/><circle cx="7" cy="7" r="0.8" fill="currentColor" stroke="none"/><circle cx="7" cy="17" r="0.8" fill="currentColor" stroke="none"/>',
  palette:
    '<path d="M12 3a9 9 0 1 0 0 18c1.2 0 1.8-.7 1.8-1.6 0-.5-.2-.9-.5-1.2-.3-.3-.5-.7-.5-1.2 0-.9.7-1.6 1.6-1.6H16a5 5 0 0 0 5-5c0-4.1-4-7.4-9-7.4Z"/><circle cx="7.5" cy="10.5" r="1" fill="currentColor" stroke="none"/><circle cx="9.5" cy="7" r="1" fill="currentColor" stroke="none"/><circle cx="14.5" cy="7" r="1" fill="currentColor" stroke="none"/>',
  plug:
    '<path d="M9 7V3M15 7V3"/><path d="M7 7h10v4a5 5 0 0 1-10 0V7Z"/><path d="M12 16v3"/><path d="M9 21h6"/>',
  "graduation-cap":
    '<path d="M12 4 2 9l10 5 10-5-10-5Z"/><path d="M6 11.5V17c0 1.5 2.7 3 6 3s6-1.5 6-3v-5.5"/><path d="M22 9v6"/>',
  headset:
    '<path d="M4 13a8 8 0 0 1 16 0"/><rect x="3" y="13" width="4" height="6" rx="1.5"/><rect x="17" y="13" width="4" height="6" rx="1.5"/><path d="M20 19a4 4 0 0 1-4 3h-2"/>',
  "check-circle":
    '<circle cx="12" cy="12" r="9"/><path d="M8 12.5l3 3 5-5.5"/>',
  smartphone:
    '<rect x="6" y="2" width="12" height="20" rx="3"/><circle cx="12" cy="17.5" r="0.8" fill="currentColor" stroke="none"/>',
  shield:
    '<path d="M12 3 4 7v5c0 4.4 3.4 8.5 8 9.5 4.6-1 8-5.1 8-9.5V7l-8-4Z"/>',
  layers:
    '<polygon points="12 2 2 7 12 12 22 7"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>',
};
---

<!-- ══ HERO ══ -->
<section class="services-hero" aria-labelledby="services-hero-title">
  <div class="services-hero-bg" aria-hidden="true"></div>
  <div class="container">
    <div class="services-hero-inner reveal">
      <p class="eyebrow eyebrow-light">{t.services.eyebrow ?? "Notre expertise"}</p>
      <h1 id="services-hero-title">{t.services.title}</h1>
      <p class="services-hero-subtitle">{t.services.subtitle}</p>
      <a href={`/${lang}/contact`} class="btn-hero">
        {t.services.cta}
        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 10h12M11 5l5 5-5 5"/></svg>
      </a>
    </div>
  </div>
</section>

<!-- ══ SERVICES + WHY ══ -->
<section id="services" class="services" aria-labelledby="services-title">
  <div class="circle-deco services-circle-1" aria-hidden="true"></div>
  <div class="container">

    <!-- Services grid -->
    <ul class="services-grid">
      {t.services.cards.map((c: any, i: number) => (
        <li class="service-card reveal" style={`transition-delay:${(i % 3) * 0.08}s`}>
          <span class="service-icon" aria-hidden="true" set:html={`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">${icons[c.icon] ?? ""}</svg>`} />
          <span class="service-num">{String(i + 1).padStart(2, "0")}</span>
          <h3>{c.title}</h3>
          <p class="benefit">{c.benefit}</p>
          <ul>
            {c.points.map((p: string) => <li>{p}</li>)}
          </ul>
        </li>
      ))}
    </ul>

    <!-- Why us — split screen -->
    <div class="why-us">
      <div class="why-header reveal">
        <h2>{t.services.whyTitle}</h2>
        <p class="why-subtitle">{t.services.whySubtitle}</p>
      </div>

      <div class="why-split" role="region" aria-label={t.services.whyTitle}>
        <!-- Left: navigation list -->
        <ul class="wsl" role="tablist">
          {t.services.why.map((w: any, i: number) => (
            <li
              class={`wsl-item${i === 0 ? " wsl-active" : ""}`}
              role="tab"
              tabindex={i === 0 ? 0 : -1}
              aria-selected={i === 0 ? "true" : "false"}
              aria-controls={`why-panel-${i}`}
              id={`why-tab-${i}`}
              data-i={i}
            >
              <div class="wsl-bar" aria-hidden="true"></div>
              <div class="wsl-body">
                <span class="wsl-num">{String(i + 1).padStart(2, "0")}</span>
                <span class="wsl-title">{w.title}</span>
              </div>
            </li>
          ))}
        </ul>

        <!-- Right: content panels -->
        <div class="wsp-wrap">
          {t.services.why.map((w: any, i: number) => (
            <div
              class={`wsp${i === 0 ? " wsp-visible" : ""}`}
              role="tabpanel"
              id={`why-panel-${i}`}
              aria-labelledby={`why-tab-${i}`}
              hidden={i !== 0}
            >
              <div class="wsp-icon" aria-hidden="true" set:html={`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">${icons[w.icon] ?? icons["check-circle"]}</svg>`} />
              <span class="wsp-num" aria-hidden="true">{String(i + 1).padStart(2, "0")}</span>
              <h3 class="wsp-title">{w.title}</h3>
              <p class="wsp-text">{w.text}</p>
            </div>
          ))}
          <!-- Progress bar -->
          <div class="wsp-progress" aria-hidden="true">
            <div class="wsp-progress-fill"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Process -->
    <h3 class="process-title reveal">{t.services.processTitle}</h3>
    <ol class="process-steps">
      {t.services.process.map((s: any, i: number) => (
        <li class="reveal" style={`transition-delay:${i * 0.1}s`}>
          <span class="step-number">{i + 1}</span>
          <h4>{s.title}</h4>
          <p>{s.text}</p>
        </li>
      ))}
    </ol>

    <!-- CTA -->
    <div class="services-cta reveal">
      <h3>{t.services.ctaTitle}</h3>
      <a href={`/${lang}/contact`} class="btn btn-primary">{t.services.cta}</a>
    </div>
  </div>
</section>

<style>
  /* ══════════════════════════════════════
     HERO
  ══════════════════════════════════════ */
  .services-hero {
    position: relative;
    min-height: 520px;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 7rem 0 5rem;
    color: #fff;
  }
  .services-hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('/images/services/services-hero.webp');
    background-size: cover;
    background-position: center top;
    z-index: 0;
  }
  .services-hero-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      rgba(2, 33, 121, 0.92) 0%,
      rgba(2, 33, 121, 0.75) 50%,
      rgba(164, 37, 147, 0.30) 100%
    );
  }
  /* Force the container to take full width inside the flex hero */
  .services-hero .container {
    position: relative;
    z-index: 1;
    width: 100%;
  }
  .services-hero-inner {
    max-width: 560px;
    /* no margin: auto — stays at the left of the container */
  }
  .eyebrow-light {
    color: rgba(255, 255, 255, 0.75);
    border-color: rgba(255, 255, 255, 0.3);
  }
  .services-hero h1 {
    color: #fff;
    font-size: clamp(2rem, 5vw, 3.4rem);
    line-height: 1.15;
    margin: 0.75rem 0 1.25rem;
  }
  .services-hero-subtitle {
    font-size: clamp(1rem, 2.2vw, 1.15rem);
    color: rgba(255, 255, 255, 0.88);
    line-height: 1.7;
    margin-bottom: 2.25rem;
  }
  .btn-hero {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9rem 1.75rem;
    border-radius: 50px;
    background: #fff;
    color: var(--color-primary);
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    box-shadow: 0 8px 28px rgba(0,0,0,0.22);
    transition: transform 0.22s ease, box-shadow 0.22s ease, background 0.22s ease;
    white-space: nowrap;
  }
  .btn-hero svg { width: 18px; height: 18px; transition: transform 0.22s ease; }
  .btn-hero:hover { background: #f5f5f5; transform: translateY(-3px); box-shadow: 0 14px 36px rgba(0,0,0,0.28); }
  .btn-hero:hover svg { transform: translateX(4px); }

  @media (max-width: 600px) {
    .services-hero { min-height: unset; padding: 5rem 0 4rem; align-items: flex-end; }
    .services-hero-bg { background-position: 70% center; }
    .services-hero-bg::after {
      background: linear-gradient(180deg,
        rgba(2,33,121,0.5) 0%,
        rgba(2,33,121,0.93) 55%,
        rgba(2,33,121,0.99) 100%
      );
    }
    .services-hero-inner { max-width: 100%; }
  }

  /* ══════════════════════════════════════
     SERVICES GRID
  ══════════════════════════════════════ */
  .services { position: relative; overflow: hidden; padding-top: 1rem; }
  .services-circle-1 { top: 10%; right: -80px; width: 220px; height: 220px; }
  .services .container { position: relative; z-index: 1; }

  .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; list-style: none; margin: 0 0 4rem; }
  .service-card {
    position: relative; padding: 2rem 1.75rem 1.75rem;
    border: 1px solid var(--color-border); border-radius: 12px;
    background: var(--color-card-bg);
    transition: transform 0.28s ease, box-shadow 0.28s ease, border-color 0.28s ease;
  }
  .service-card:hover { transform: translateY(-8px); box-shadow: 0 22px 40px rgba(2,33,121,0.12); border-color: var(--color-accent); }
  .service-icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 48px; height: 48px; border-radius: 10px;
    background: var(--color-bg-secondary); color: var(--color-accent);
    margin-bottom: 1rem;
    transition: background 0.28s ease, color 0.28s ease, transform 0.28s ease;
  }
  .service-icon svg { width: 24px; height: 24px; }
  .service-card:hover .service-icon { background: var(--color-accent); color: #fff; transform: scale(1.08) rotate(-4deg); }
  .service-num { position: absolute; top: 1.75rem; right: 1.75rem; color: var(--color-text-secondary); font-size: 0.85rem; opacity: 0.5; }
  .service-card .benefit { font-weight: 500; color: var(--color-text); margin: 0.5rem 0; }
  .service-card ul { margin-top: 0.5rem; padding-left: 1.1rem; color: var(--color-text-secondary); font-size: 0.9rem; }
  .service-card ul li + li { margin-top: 0.2rem; }

  /* ══════════════════════════════════════
     WHY US — SPLIT SCREEN
  ══════════════════════════════════════ */
  .why-us {
    margin-bottom: 4rem;
    padding: 4rem 2.5rem 3.5rem;
    background: linear-gradient(160deg, var(--color-bg-secondary) 0%, var(--color-bg) 100%);
    border-radius: 20px;
  }
  .why-header { text-align: center; margin-bottom: 3rem; }
  .why-header h2 { margin-bottom: 1rem; }
  .why-subtitle {
    max-width: 640px; margin: 0 auto;
    color: var(--color-text-secondary); font-size: 1.05rem; line-height: 1.7;
  }

  /* Split layout */
  .why-split {
    display: grid;
    grid-template-columns: 38% 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  /* ── Left: nav list ── */
  .wsl { list-style: none; display: flex; flex-direction: column; gap: 0; }
  .wsl-item {
    display: flex;
    align-items: stretch;
    gap: 0;
    cursor: pointer;
    border-radius: 10px;
    padding: 0.85rem 1rem;
    transition: background 0.2s;
    outline: none;
  }
  .wsl-item:hover { background: var(--color-card-bg); }
  .wsl-bar {
    width: 3px;
    border-radius: 4px;
    background: var(--color-border);
    margin-right: 1rem;
    flex-shrink: 0;
    transition: background 0.3s;
    align-self: stretch;
    min-height: 100%;
  }
  .wsl-item.wsl-active .wsl-bar { background: linear-gradient(180deg, #A42593, #022179); }
  .wsl-body { display: flex; flex-direction: column; gap: 0.15rem; }
  .wsl-num {
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.06em;
    color: var(--color-text-secondary); opacity: 0.6;
    transition: color 0.2s, opacity 0.2s;
  }
  .wsl-item.wsl-active .wsl-num { color: var(--color-accent); opacity: 1; }
  .wsl-title {
    font-size: 0.95rem; font-weight: 600;
    color: var(--color-text-secondary);
    line-height: 1.35;
    transition: color 0.2s;
  }
  .wsl-item.wsl-active .wsl-title { color: var(--color-text); }

  /* ── Right: content panel ── */
  .wsp-wrap {
    position: relative;
    min-height: 280px;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    background: var(--color-card-bg);
    overflow: hidden;
  }
  .wsp {
    padding: 2.25rem 2rem 3.5rem;
    animation: wsp-in 0.4s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .wsp[hidden] { display: none; }
  @keyframes wsp-in {
    from { opacity: 0; transform: translateX(22px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  .wsp-icon {
    width: 56px; height: 56px; border-radius: 14px;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1.5rem;
  }
  .wsp-icon svg { width: 26px; height: 26px; }
  .wsp-num {
    display: block; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.08em;
    color: var(--color-accent); margin-bottom: 0.5rem;
  }
  .wsp-title {
    font-size: 1.25rem; font-weight: 700;
    color: var(--color-text); margin-bottom: 0.85rem; line-height: 1.3;
  }
  .wsp-text {
    font-size: 0.95rem; color: var(--color-text-secondary);
    line-height: 1.75; margin: 0;
  }

  /* Progress bar at bottom of panel */
  .wsp-progress {
    position: absolute; bottom: 0; left: 0; right: 0;
    height: 3px; background: var(--color-border);
  }
  .wsp-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #A42593, #022179);
    transform: scaleX(0);
    transform-origin: left;
    border-radius: 0 2px 2px 0;
  }
  .wsp-progress-fill.running {
    animation: prog-fill var(--why-duration, 3.5s) linear forwards;
  }
  @keyframes prog-fill { to { transform: scaleX(1); } }

  /* ══════════════════════════════════════
     PROCESS TIMELINE
  ══════════════════════════════════════ */
  .process-title { margin-bottom: 2rem; }
  .process-steps {
    list-style: none; display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem; margin-bottom: 3.5rem; position: relative;
  }
  .process-steps::before {
    content: ""; position: absolute; top: 1.25rem; left: 6%; right: 6%;
    height: 2px; background: linear-gradient(90deg, var(--color-accent), var(--color-border)); z-index: 0;
  }
  .process-steps li { position: relative; z-index: 1; }
  .step-number {
    display: flex; align-items: center; justify-content: center;
    width: 2.5rem; height: 2.5rem; border-radius: 50%;
    background: var(--color-accent); color: #fff;
    font-size: 1.1rem; font-weight: 700; margin-bottom: 0.85rem;
    box-shadow: 0 8px 18px rgba(164,37,147,0.35);
  }

  /* ══════════════════════════════════════
     CLOSING CTA
  ══════════════════════════════════════ */
  .services-cta {
    text-align: center; padding: 3rem 2rem; border-radius: 16px;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    color: #fff;
  }
  .services-cta h3 { color: #fff; margin-bottom: 1.25rem; }
  .services-cta .btn-primary { background: #fff; color: var(--color-primary); }
  .services-cta .btn-primary:hover { background: #f1f1f1; }

  /* ══════════════════════════════════════
     RESPONSIVE
  ══════════════════════════════════════ */
  @media (max-width: 900px) {
    .services-grid, .process-steps { grid-template-columns: 1fr 1fr; }
    .process-steps::before { display: none; }
    .why-split { grid-template-columns: 1fr; gap: 1.5rem; }
    /* On tablet/mobile, list becomes horizontal tabs */
    .wsl { flex-direction: row; flex-wrap: wrap; gap: 0.5rem; }
    .wsl-item { flex-direction: column; align-items: flex-start; padding: 0.6rem 0.9rem; border: 1px solid var(--color-border); border-radius: 8px; gap: 0.2rem; }
    .wsl-bar { width: 100%; height: 2px; min-height: unset; margin-right: 0; margin-bottom: 0.3rem; border-radius: 2px; }
    .wsl-item.wsl-active { border-color: var(--color-accent); background: var(--color-card-bg); }
    .wsl-title { font-size: 0.82rem; }
    .wsp-wrap { min-height: 220px; }
    .why-us { padding: 3rem 1.5rem 2.5rem; }
  }
  @media (max-width: 600px) {
    .services-grid { grid-template-columns: 1fr; }
    .process-steps { grid-template-columns: 1fr 1fr; }
    .wsl-title { font-size: 0.78rem; }
    .wsp { padding: 1.5rem 1.25rem 3rem; }
    .wsp-title { font-size: 1.1rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .wsp { animation: none; }
    .wsp-progress-fill, .wsp-progress-fill.running { animation: none; transform: scaleX(1); }
  }
</style>

<script>
(function () {
  const DURATION = 3500;

  const tabs    = Array.from(document.querySelectorAll(".wsl-item"))   as HTMLElement[];
  const panels  = Array.from(document.querySelectorAll(".wsp"))        as HTMLElement[];
  const progFill = document.querySelector(".wsp-progress-fill")        as HTMLElement | null;

  if (!tabs.length || !panels.length) return;

  progFill?.style.setProperty("--why-duration", DURATION + "ms");

  let current = 0;
  let timer   = 0;
  let paused  = false;

  function goTo(i: number) {
    current = ((i % tabs.length) + tabs.length) % tabs.length;

    tabs.forEach((t, idx) => {
      const active = idx === current;
      t.classList.toggle("wsl-active", active);
      t.setAttribute("aria-selected", active ? "true" : "false");
      t.tabIndex = active ? 0 : -1;
    });

    panels.forEach((p, idx) => {
      if (idx === current) {
        p.hidden = false;
        p.classList.add("wsp-visible");
      } else {
        p.hidden = true;
        p.classList.remove("wsp-visible");
      }
    });

    /* Restart progress bar */
    if (progFill) {
      progFill.classList.remove("running");
      void progFill.offsetWidth;
      progFill.style.setProperty("--why-duration", DURATION + "ms");
      progFill.classList.add("running");
    }
  }

  function startTimer() {
    clearInterval(timer);
    timer = window.setInterval(() => {
      if (!paused) goTo(current + 1);
    }, DURATION);
  }

  /* Init */
  goTo(0);
  startTimer();

  /* Tab clicks */
  tabs.forEach((tab, i) => {
    tab.addEventListener("click", () => {
      goTo(i);
      startTimer();
    });
    /* Keyboard navigation */
    tab.addEventListener("keydown", (e: KeyboardEvent) => {
      if (e.key === "ArrowDown" || e.key === "ArrowRight") { e.preventDefault(); goTo(current + 1); startTimer(); }
      if (e.key === "ArrowUp"   || e.key === "ArrowLeft")  { e.preventDefault(); goTo(current - 1); startTimer(); }
    });
  });

  /* Pause on hover */
  const section = document.querySelector(".why-us");
  section?.addEventListener("mouseenter", () => { paused = true; });
  section?.addEventListener("mouseleave", () => { paused = false; });
})();
</script>
