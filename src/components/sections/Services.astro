---
import type { Lang } from "../../i18n/utils";
import { useTranslations } from "../../i18n/utils";

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

const icons: Record<string, string> = {
  rocket:
    '<path d="M12 2c2.5 2 4 5.5 4 9 0 2-1 4-2 5l-2 2-2-2c-1-1-2-3-2-5 0-3.5 1.5-7 4-9Z"/><circle cx="12" cy="10" r="1.6"/><path d="M9 16l-2.5 1.5L7 14"/><path d="M15 16l2.5 1.5L17 14"/>',
  server:
    '<rect x="3.5" y="4" width="17" height="6" rx="1.5"/><rect x="3.5" y="14" width="17" height="6" rx="1.5"/><circle cx="7" cy="7" r="0.8" fill="currentColor" stroke="none"/><circle cx="7" cy="17" r="0.8" fill="currentColor" stroke="none"/>',
  palette:
    '<path d="M12 3a9 9 0 1 0 0 18c1.2 0 1.8-.7 1.8-1.6 0-.5-.2-.9-.5-1.2-.3-.3-.5-.7-.5-1.2 0-.9.7-1.6 1.6-1.6H16a5 5 0 0 0 5-5c0-4.1-4-7.4-9-7.4Z"/><circle cx="7.5" cy="10.5" r="1" fill="currentColor" stroke="none"/><circle cx="9.5" cy="7" r="1" fill="currentColor" stroke="none"/><circle cx="14.5" cy="7" r="1" fill="currentColor" stroke="none"/>',
  plug:
    '<path d="M9 7V3M15 7V3"/><path d="M7 7h10v4a5 5 0 0 1-10 0V7Z"/><path d="M12 16v3"/><path d="M9 21h6"/>',
  "graduation-cap":
    '<path d="M12 4 2 9l10 5 10-5-10-5Z"/><path d="M6 11.5V17c0 1.5 2.7 3 6 3s6-1.5 6-3v-5.5"/><path d="M22 9v6"/>',
  headset:
    '<path d="M4 13a8 8 0 0 1 16 0"/><rect x="3" y="13" width="4" height="6" rx="1.5"/><rect x="17" y="13" width="4" height="6" rx="1.5"/><path d="M20 19a4 4 0 0 1-4 3h-2"/>',
};
---

<section class="services-hero">
  <div class="container services-hero-grid">
    <div class="services-hero-text reveal">
      <p class="eyebrow">{t.services.eyebrow ?? "Notre expertise"}</p>
      <h1>{t.services.title}</h1>
      <p class="services-subtitle">{t.services.subtitle}</p>
      <div class="services-hero-cta">
        <a href={`/${lang}/contact`} class="btn btn-primary">{t.services.cta}</a>
      </div>
    </div>
    <figure class="services-hero-visual reveal">
      <img src="/images/services/services-hero.jpg" alt="" loading="eager" width="640" height="486" />
    </figure>
  </div>
</section>

<section id="services" class="services" aria-labelledby="services-title">
  <div class="circle-deco services-circle-1" aria-hidden="true"></div>
  <div class="container">
    <ul class="services-grid">
      {t.services.cards.map((c: any, i: number) => (
        <li class="service-card reveal" style={`transition-delay:${(i % 3) * 0.08}s`}>
          <span class="service-icon" aria-hidden="true" set:html={`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">${icons[c.icon] ?? ""}</svg>`} />
          <span class="service-num">{String(i + 1).padStart(2, "0")}</span>
          <h3>{c.title}</h3>
          <p class="benefit">{c.benefit}</p>
          <ul>
            {c.points.map((p: string) => <li>{p}</li>)}
          </ul>
        </li>
      ))}
    </ul>

    <div class="why-us">
      <h3 class="reveal">{t.services.whyTitle}</h3>
      <ul class="why-grid">
        {t.services.why.map((w: any, i: number) => (
          <li class="why-item reveal" style={`transition-delay:${(i % 3) * 0.07}s`}>
            <span class="why-check" aria-hidden="true">✓</span>
            <h4>{w.title}</h4>
            <p>{w.text}</p>
          </li>
        ))}
      </ul>
    </div>

    <h3 class="process-title reveal">{t.services.processTitle}</h3>
    <ol class="process-steps">
      {t.services.process.map((s: any, i: number) => (
        <li class="reveal" style={`transition-delay:${i * 0.1}s`}>
          <span class="step-number">{i + 1}</span>
          <h4>{s.title}</h4>
          <p>{s.text}</p>
        </li>
      ))}
    </ol>

    <div class="services-cta reveal">
      <h3>{t.services.whyTitle}</h3>
      <a href={`/${lang}/contact`} class="btn btn-primary">{t.services.cta}</a>
    </div>
  </div>
</section>

<style>
  /* ---------- Hero banner ---------- */
  .services-hero { position: relative; overflow: hidden; padding: 3rem 0 1rem; }
  .services-hero-grid { display: grid; grid-template-columns: 1.3fr 1fr; gap: 3.5rem; align-items: center; }
  .services-subtitle { max-width: 540px; margin: 1.25rem 0 1.75rem; font-size: 1.1rem; }
  .services-hero-visual {
    position: relative;
    margin: 0;
  }
  .services-hero-visual img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 10px;
    transform: rotate(-1.5deg);
    box-shadow: 0 24px 48px rgba(2, 33, 121, 0.22);
    transition: transform 0.35s ease;
  }
  .services-hero-visual:hover img { transform: rotate(0deg) scale(1.02); }

  /* ---------- Services grid ---------- */
  .services { position: relative; overflow: hidden; padding-top: 1rem; }
  .services-circle-1 { top: 10%; right: -80px; width: 220px; height: 220px; }
  .services .container { position: relative; z-index: 1; }

  .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; list-style: none; margin: 0 0 4rem; }
  .service-card {
    position: relative;
    padding: 2rem 1.75rem 1.75rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: var(--color-card-bg);
    transition: transform 0.28s ease, box-shadow 0.28s ease, border-color 0.28s ease;
  }
  .service-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 22px 40px rgba(2, 33, 121, 0.12);
    border-color: var(--color-accent);
  }
  .service-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 10px;
    background: var(--color-bg-secondary);
    color: var(--color-accent);
    margin-bottom: 1rem;
    transition: background 0.28s ease, color 0.28s ease, transform 0.28s ease;
  }
  .service-icon svg { width: 24px; height: 24px; }
  .service-card:hover .service-icon { background: var(--color-accent); color: #fff; transform: scale(1.08) rotate(-4deg); }
  .service-num { position: absolute; top: 1.75rem; right: 1.75rem; color: var(--color-text-secondary); font-size: 0.85rem; opacity: 0.5; }
  .service-card .benefit { font-weight: 500; color: var(--color-text); margin: 0.5rem 0; }
  .service-card ul { margin-top: 0.5rem; padding-left: 1.1rem; color: var(--color-text-secondary); font-size: 0.9rem; }
  .service-card ul li + li { margin-top: 0.2rem; }

  /* ---------- Why us ---------- */
  .why-us { margin-bottom: 4rem; }
  .why-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem 2rem; list-style: none; margin-top: 1.5rem; }
  .why-item { position: relative; padding-left: 2.4rem; }
  .why-check {
    position: absolute;
    left: 0;
    top: 0.1rem;
    width: 1.6rem;
    height: 1.6rem;
    border-radius: 50%;
    background: var(--color-accent);
    color: #fff;
    font-size: 0.85rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ---------- Process timeline ---------- */
  .process-title { margin-bottom: 2rem; }
  .process-steps {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-bottom: 3.5rem;
    position: relative;
  }
  .process-steps::before {
    content: "";
    position: absolute;
    top: 1.25rem;
    left: 6%;
    right: 6%;
    height: 2px;
    background: linear-gradient(90deg, var(--color-accent), var(--color-border));
    z-index: 0;
  }
  .process-steps li { position: relative; z-index: 1; }
  .step-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: var(--color-accent);
    color: #fff;
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.85rem;
    box-shadow: 0 8px 18px rgba(164, 37, 147, 0.35);
  }

  /* ---------- Closing CTA ---------- */
  .services-cta {
    text-align: center;
    padding: 3rem 2rem;
    border-radius: 16px;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    color: #fff;
  }
  .services-cta h3 { color: #fff; margin-bottom: 1.25rem; }
  .services-cta .btn-primary { background: #fff; color: var(--color-primary); }
  .services-cta .btn-primary:hover { background: #f1f1f1; }

  @media (max-width: 900px) {
    .services-hero-grid { grid-template-columns: 1fr; }
    .services-hero-visual { order: -1; }
    .services-grid, .why-grid, .process-steps { grid-template-columns: 1fr; }
    .process-steps::before { display: none; }
  }
</style>
