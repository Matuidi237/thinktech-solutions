---
import type { Lang } from "../../i18n/utils";
import { useTranslations } from "../../i18n/utils";

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="accueil" class="hero" aria-labelledby="hero-title">
  <div class="hero-fullbg">
    <img src="/images/hero/hero-accueil.jpg" alt={t.hero.heroImageAlt} loading="eager" width="1440" height="810" class="hero-bg-img" />
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="hero-top">
      <div class="hero-text reveal">
        <h1 id="hero-title">{t.hero.title}</h1>
        <p class="hero-subtitle">{t.hero.subtitle}</p>
        <div class="hero-cta">
          <a href={`/${lang}/contact`} class="btn btn-primary">{t.hero.ctaPrimary}</a>
          <a href={`/${lang}/services`} class="btn btn-secondary btn-secondary--light">{t.hero.ctaSecondary}</a>
        </div>
      </div>
    </div>
  </div>

  <div class="container hero-platforms" style="position: relative;">
    <div class="circle-deco circle-fill hero-circle-3" aria-hidden="true"></div>
    <h2 class="carousel-title">{t.hero.platformsTitle}</h2>
    <div class="pc-outer">
      <button class="pc-arrow pc-arrow--prev" aria-label="Précédent" id="pcPrev">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <div class="pc-viewport" id="pcViewport">
        <div class="platforms-grid" id="platformsGrid">
          {t.hero.platforms.map((p: any) => {
            return (
              <a class="platform-card" href={`/${lang}/realisations`}>
                <div class="platform-thumb">
                  <img src={p.image} alt={p.name} width="400" height="260" loading="eager" />
                </div>
                <div class="platform-info">
                  <h3>{p.name}</h3>
                  <p>{p.description}</p>
                </div>
              </a>
            );
          })}
        </div>
      </div>
      <button class="pc-arrow pc-arrow--next" aria-label="Suivant" id="pcNext">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
    <div class="pc-dots" id="pcDots"></div>

    <h2 class="carousel-title">{t.hero.partnersTitle}</h2>
    <div class="carousel" aria-label={t.hero.partnersTitle}>
      <div class="carousel-track">
        {t.hero.partners.map((p: any) => (
          <div class="partner-logo">
            <img src={p.logo} alt={p.name} loading="lazy" />
          </div>
        ))}
      </div>
    </div>

    <ul class="trust-metrics">
      {t.hero.metrics.map((m: any) => (
        <li><strong>{m.value}</strong><span>{m.label}</span></li>
      ))}
    </ul>
  </div>
</section>

<style>
  .hero { position: relative; overflow: hidden; padding-top: 0; }

  .hero-fullbg {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .hero-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    z-index: 0;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(2,33,121,0.92) 0%, rgba(2,33,121,0.75) 45%, rgba(2,33,121,0.2) 72%, rgba(2,33,121,0) 100%);
    z-index: 1;
  }
  .hero-top {
    position: relative;
    z-index: 2;
    padding: 8rem 2rem 5rem 1.5rem;
  }
  .hero-text { max-width: 42%; }
  .hero-text h1 { color: #fff; margin-bottom: 1.5rem; font-size: clamp(2.4rem, 4.5vw, 4rem); line-height: 1.05; }
  .hero-subtitle { margin: 0 0 2.5rem; font-size: clamp(1rem, 1.4vw, 1.15rem); max-width: 520px; color: #fff; line-height: 1.7; }
  .hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; }
  .btn-secondary--light {
    background: rgba(255,255,255,0.12);
    color: #fff;
    border: 1.5px solid rgba(255,255,255,0.5);
    backdrop-filter: blur(4px);
  }
  .btn-secondary--light:hover { background: rgba(255,255,255,0.22); border-color: #fff; }

  .hero-circle-3 { top: -30px; right: 12%; width: 150px; height: 150px; }
  .carousel-title { position: relative; z-index: 1; font-size: 1.1rem; margin: 2rem 0 1rem; color: var(--color-text-secondary); font-weight: 600; }

  .pc-outer { position: relative; z-index: 1; display: flex; align-items: center; gap: 0.75rem; }
  .pc-viewport { overflow: hidden; flex: 1; }
  .platforms-grid { display: flex; gap: 1.5rem; transition: transform 0.45s cubic-bezier(0.22,1,0.36,1); will-change: transform; }
  .platform-card { flex: 0 0 calc((100% - 3rem) / 3); min-width: 0; }
  .platform-card {
    display: flex;
    flex-direction: column;
    border-radius: 18px;
    background: var(--color-bg-secondary);
    overflow: hidden;
    text-decoration: none;
    color: var(--color-text);
    border: 1px solid var(--color-border);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .platform-card:hover,
  .platform-card:focus-visible {
    transform: translateY(-6px);
    box-shadow: 0 22px 40px -16px rgba(2, 33, 121, 0.28);
    border-color: var(--color-accent);
  }

  .platform-thumb {
    aspect-ratio: 16 / 10;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.6rem;
    border-bottom: 1px solid var(--color-border);
  }
  .platform-thumb img { width: 100%; height: 100%; object-fit: contain; border-radius: 8px; }

  .platform-info { padding: 1.25rem 1.5rem 1.5rem; }
  .platform-info h3 { margin-bottom: 0.4rem; display: flex; align-items: center; gap: 0.5rem; }
  .platform-info p { font-size: 0.9rem; margin: 0; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }

  .carousel { overflow: hidden; }
  .partner-logo {
    min-width: 160px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.25rem;
  }
  .partner-logo img { max-width: 100%; max-height: 100%; width: auto; height: auto; object-fit: contain; }
  .trust-metrics { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; list-style: none; margin: 3.5rem 0; border-top: 1px solid var(--color-border); }
  .trust-metrics li { padding: 1.5rem 1.25rem 0; border-left: 1px solid var(--color-border); }
  .trust-metrics li:first-child { border-left: none; }
  .trust-metrics strong { display: block; font-size: 2.25rem; font-weight: 800; color: var(--color-accent); }
  .trust-metrics span { color: var(--color-text-secondary); font-size: 0.9rem; }

  .pc-arrow {
    flex-shrink: 0;
    width: 40px; height: 40px;
    border-radius: 50%;
    border: 1.5px solid var(--color-border);
    background: var(--color-bg-secondary);
    color: var(--color-text);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s, transform 0.2s;
    z-index: 2;
  }
  .pc-arrow:hover { border-color: var(--color-accent); background: var(--color-accent); color: #fff; transform: scale(1.08); }
  .pc-arrow:disabled { opacity: 0.3; pointer-events: none; }

  .pc-dots { display: flex; gap: 6px; justify-content: center; margin-top: 1.25rem; }
  .pc-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--color-border);
    border: none; cursor: pointer; padding: 0;
    transition: background 0.25s, transform 0.25s;
  }
  .pc-dot.active { background: var(--color-accent); transform: scale(1.3); }

  @media (max-width: 900px) {
    .hero-fullbg { min-height: 75vh; }
    .platform-card { flex: 0 0 calc((100% - 1.5rem) / 2); }
    .trust-metrics { grid-template-columns: repeat(2, 1fr); }
    .trust-metrics li { border-left: none; border-top: 1px solid var(--color-border); padding: 1.25rem 0 0; }
    .trust-metrics li:nth-child(odd) { border-left: none; }
  }

  @media (max-width: 640px) {
    .hero-fullbg { min-height: 65vh; }
    .hero-text { max-width: 100%; }
    .hero-top { padding-top: 5.5rem; padding-bottom: 3.5rem; }
    .platform-card { flex: 0 0 82%; }
    .pc-arrow { width: 32px; height: 32px; }
    .pc-arrow svg { width: 16px; height: 16px; }
  }
</style>

<script is:inline src="/scripts/carousel.js"></script>
<script is:inline src="/scripts/counter.js"></script>
<script is:inline>
(function() {
  var grid = document.getElementById('platformsGrid');
  var prev = document.getElementById('pcPrev');
  var next = document.getElementById('pcNext');
  var dotsEl = document.getElementById('pcDots');
  if (!grid || !prev || !next) return;

  var cards = grid.querySelectorAll('.platform-card');
  var total = cards.length;
  var visible = window.innerWidth <= 640 ? 1 : window.innerWidth <= 900 ? 2 : 3;
  var maxIndex = Math.max(0, total - visible);
  var idx = 0;

  // Build dots
  for (var i = 0; i <= maxIndex; i++) {
    var d = document.createElement('button');
    d.className = 'pc-dot' + (i === 0 ? ' active' : '');
    d.setAttribute('aria-label', 'Projet ' + (i + 1));
    d.dataset.i = i;
    dotsEl.appendChild(d);
  }

  function update() {
    var cardW = cards[0].getBoundingClientRect().width;
    var gap = 24;
    grid.style.transform = 'translateX(-' + (idx * (cardW + gap)) + 'px)';
    prev.disabled = idx === 0;
    next.disabled = idx >= maxIndex;
    dotsEl.querySelectorAll('.pc-dot').forEach(function(d, i) {
      d.classList.toggle('active', i === idx);
    });
  }

  prev.addEventListener('click', function() { if (idx > 0) { idx--; update(); } });
  next.addEventListener('click', function() { if (idx < maxIndex) { idx++; update(); } });
  dotsEl.addEventListener('click', function(e) {
    var d = e.target.closest('.pc-dot');
    if (d) { idx = +d.dataset.i; update(); }
  });

  update();
  window.addEventListener('resize', function() {
    visible = window.innerWidth <= 640 ? 1 : window.innerWidth <= 900 ? 2 : 3;
    maxIndex = Math.max(0, total - visible);
    idx = Math.min(idx, maxIndex);
    update();
  });
})();
</script>
