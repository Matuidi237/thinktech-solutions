---
import type { Lang } from "../../i18n/utils";
import { useTranslations } from "../../i18n/utils";

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const r = t.realisations;
const [bouka, training, erfolg, lasalle] = r.projects;

const projectScreens: Record<string, string[]> = {
  "bouka": [
    "/images/platforms/bouka-creativ-home.png",
    "/images/platforms/bouka-creativ-course.png",
    "/images/platforms/bouka-creativ-login.png",
  ],
  "training": [
    "/images/platforms/training-to-rise-home.png",
    "/images/platforms/training-to-rise-courses.png",
    "/images/platforms/training-to-rise-course1.png",
  ],
  "erfolg": [
    "/images/platforms/Erfolg1.png",
    "/images/platforms/Erfolg2.png",
    "/images/platforms/Erfolg3.png",
    "/images/platforms/Erfolg4.png",
    "/images/platforms/Erfolg5.png",
    "/images/platforms/Erfolg6.png",
    "/images/platforms/Erfolg7.png",
    "/images/platforms/Erfolg8.png",
  ],
  "lasalle": [
    "/images/platforms/Lasalle-Courses-Page%20(1).png",
    "/images/platforms/Lasalle-Courses-Page%20(2).png",
    "/images/platforms/Lasalle-Courses-Page%20(3).png",
    "/images/platforms/Lasalle-Courses-Page%20(4).png",
    "/images/platforms/Lasalle-Courses-Page%20(5).png",
    "/images/platforms/Lasalle-Courses-Page%20(6).png",
    "/images/platforms/Lasalle-Courses-Page%20(7).png",
    "/images/platforms/Lasalle-Courses-Page%20(8).png",
  ],
};
---

<!-- ══ HERO ══ -->
<section class="rh" aria-labelledby="rh-title">
  <div class="rh-bg" aria-hidden="true"></div>
  <div class="container">
    <div class="rh-inner">
      <span class="rh-eyebrow rh-anim" style="--d:0s">{r.eyebrow}</span>
      <h1 id="rh-title" class="rh-title rh-anim" style="--d:.1s">{r.heroTitle}</h1>
      <p class="rh-sub rh-anim" style="--d:.2s">{r.heroSub}</p>
      <ul class="rh-stats rh-anim" style="--d:.32s">
        <li>
          <span class="rh-stat-val" data-count="3">3</span>
          <span class="rh-stat-lbl">{r.statProjects}</span>
        </li>
        <li>
          <span class="rh-stat-val" data-count="42000">42 000</span>
          <span class="rh-stat-lbl">{r.statLearners}</span>
        </li>
        <li>
          <span class="rh-stat-val" data-count="50">50</span>
          <span class="rh-stat-lbl">{r.statHours}</span>
        </li>
      </ul>
    </div>
  </div>
</section>

<!-- ══ PROJETS ══ -->
<section class="rl-projects">
  <div class="container">

    <!-- Projet 1 — Bouka -->
    <article class="rl-item rl-reveal">
      <div class="rl-info">
        <span class="rl-num">01</span>
        <p class="rl-sector">{bouka.sector}</p>
        <h2 class="rl-name">{bouka.name}</h2>
        <p class="rl-client">{bouka.client}</p>
        <p class="rl-desc">{bouka.description}</p>
        <ul class="rl-tags">
          {bouka.tags.map((tag: string) => <li>{tag}</li>)}
        </ul>
        <div class="rl-kpi">
          <span class="rl-kpi-val">{bouka.metric.value}</span>
          <span class="rl-kpi-lbl">{bouka.metric.label}</span>
        </div>
        {bouka.url && (
          <a href={bouka.url} target="_blank" rel="noopener noreferrer" class="rl-link">
            {r.visitLabel}
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="13" height="13" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
          </a>
        )}
      </div>

      <div class="rl-carousel" data-carousel data-project={bouka.name}>
        <div class="rl-carousel-track">
          {projectScreens.bouka.map((src, i) => (
            <div class="rl-slide">
              <div class="rl-bar" aria-hidden="true"><span></span><span></span><span></span></div>
              <button class="rl-zoom-btn" data-src={src} data-idx={i} aria-label="Agrandir l'image">
                <img src={src} alt={`${bouka.name} — vue ${i + 1}`} width="700" height="420" loading={i === 0 ? "eager" : "lazy"} />
                <span class="rl-zoom-hint" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35M11 8v6M8 11h6"/></svg>
                </span>
              </button>
            </div>
          ))}
        </div>
        <div class="rl-carousel-footer">
          <div class="rl-dots" aria-hidden="true">
            {projectScreens.bouka.map((_: string, i: number) => (
              <button class={`rl-dot${i === 0 ? " rl-dot--active" : ""}`} data-index={i}></button>
            ))}
          </div>
          {projectScreens.bouka.length > 1 && (
            <div class="rl-arrows">
              <button class="rl-arrow rl-arrow--prev" aria-label="Image précédente">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M15 18l-6-6 6-6"/></svg>
              </button>
              <button class="rl-arrow rl-arrow--next" aria-label="Image suivante">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M9 18l6-6-6-6"/></svg>
              </button>
            </div>
          )}
        </div>
      </div>
    </article>

    <!-- Projet 2 — Training To Rise (inversé) -->
    <article class="rl-item rl-item--reverse rl-reveal">
      <div class="rl-info">
        <span class="rl-num">02</span>
        <p class="rl-sector">{training.sector}</p>
        <h2 class="rl-name">{training.name}</h2>
        <p class="rl-client">{training.client}</p>
        <p class="rl-desc">{training.description}</p>
        <ul class="rl-tags">
          {training.tags.map((tag: string) => <li>{tag}</li>)}
        </ul>
        <div class="rl-kpi">
          <span class="rl-kpi-val">{training.metric.value}</span>
          <span class="rl-kpi-lbl">{training.metric.label}</span>
        </div>
      </div>

      <div class="rl-carousel" data-carousel data-project={training.name}>
        <div class="rl-carousel-track">
          {projectScreens.training.map((src, i) => (
            <div class="rl-slide">
              <div class="rl-bar" aria-hidden="true"><span></span><span></span><span></span></div>
              <button class="rl-zoom-btn" data-src={src} data-idx={i} aria-label="Agrandir l'image">
                <img src={src} alt={`${training.name} — vue ${i + 1}`} width="700" height="420" loading={i === 0 ? "eager" : "lazy"} />
                <span class="rl-zoom-hint" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35M11 8v6M8 11h6"/></svg>
                </span>
              </button>
            </div>
          ))}
        </div>
        <div class="rl-carousel-footer">
          <div class="rl-dots" aria-hidden="true">
            {projectScreens.training.map((_: string, i: number) => (
              <button class={`rl-dot${i === 0 ? " rl-dot--active" : ""}`} data-index={i}></button>
            ))}
          </div>
          {projectScreens.training.length > 1 && (
            <div class="rl-arrows">
              <button class="rl-arrow rl-arrow--prev" aria-label="Image précédente">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M15 18l-6-6 6-6"/></svg>
              </button>
              <button class="rl-arrow rl-arrow--next" aria-label="Image suivante">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M9 18l6-6-6-6"/></svg>
              </button>
            </div>
          )}
        </div>
      </div>
    </article>

    <!-- Projet 3 — Erfolg -->
    <article class="rl-item rl-reveal">
      <div class="rl-info">
        <span class="rl-num">03</span>
        <p class="rl-sector">{erfolg.sector}</p>
        <h2 class="rl-name">{erfolg.name}</h2>
        <p class="rl-client">{erfolg.client}</p>
        <p class="rl-desc">{erfolg.description}</p>
        <ul class="rl-tags">
          {erfolg.tags.map((tag: string) => <li>{tag}</li>)}
        </ul>
        <div class="rl-kpi">
          <span class="rl-kpi-val">{erfolg.metric.value}</span>
          <span class="rl-kpi-lbl">{erfolg.metric.label}</span>
        </div>
        {erfolg.url && (
          <a href={erfolg.url} target="_blank" rel="noopener noreferrer" class="rl-link">
            {r.visitLabel}
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="13" height="13" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
          </a>
        )}
      </div>

      <div class="rl-carousel" data-carousel data-project={erfolg.name}>
        <div class="rl-carousel-track">
          {projectScreens.erfolg.map((src, i) => (
            <div class="rl-slide">
              <div class="rl-bar" aria-hidden="true"><span></span><span></span><span></span></div>
              <button class="rl-zoom-btn" data-src={src} data-idx={i} aria-label="Agrandir l'image">
                <img src={src} alt={`${erfolg.name} — vue ${i + 1}`} width="700" height="420" loading={i === 0 ? "eager" : "lazy"} />
                <span class="rl-zoom-hint" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35M11 8v6M8 11h6"/></svg>
                </span>
              </button>
            </div>
          ))}
        </div>
        <div class="rl-carousel-footer">
          <div class="rl-dots" aria-hidden="true">
            {projectScreens.erfolg.map((_: string, i: number) => (
              <button class={`rl-dot${i === 0 ? " rl-dot--active" : ""}`} data-index={i}></button>
            ))}
          </div>
          {projectScreens.erfolg.length > 1 && (
            <div class="rl-arrows">
              <button class="rl-arrow rl-arrow--prev" aria-label="Image précédente">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M15 18l-6-6 6-6"/></svg>
              </button>
              <button class="rl-arrow rl-arrow--next" aria-label="Image suivante">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M9 18l6-6-6-6"/></svg>
              </button>
            </div>
          )}
        </div>
      </div>
    </article>

    <!-- Projet 4 — LaSalle -->
    <article class="rl-item rl-item--reverse rl-reveal">
      <div class="rl-info">
        <span class="rl-num">04</span>
        <p class="rl-sector">{lasalle.sector}</p>
        <h2 class="rl-name">{lasalle.name}</h2>
        <p class="rl-client">{lasalle.client}</p>
        <p class="rl-desc">{lasalle.description}</p>
        <ul class="rl-tags">
          {lasalle.tags.map((tag: string) => <li>{tag}</li>)}
        </ul>
        <div class="rl-kpi">
          <span class="rl-kpi-val">{lasalle.metric.value}</span>
          <span class="rl-kpi-lbl">{lasalle.metric.label}</span>
        </div>
        {lasalle.url && (
          <a href={lasalle.url} target="_blank" rel="noopener noreferrer" class="rl-link">
            {r.visitLabel}
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="13" height="13" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
          </a>
        )}
      </div>

      <div class="rl-carousel" data-carousel data-project={lasalle.name}>
        <div class="rl-carousel-track">
          {projectScreens.lasalle.map((src, i) => (
            <div class="rl-slide">
              <div class="rl-bar" aria-hidden="true"><span></span><span></span><span></span></div>
              <button class="rl-zoom-btn" data-src={src} data-idx={i} aria-label="Agrandir l'image">
                <img src={src} alt={`${lasalle.name} — vue ${i + 1}`} width="700" height="420" loading="lazy" />
                <span class="rl-zoom-hint" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35M11 8v6M8 11h6"/></svg>
                </span>
              </button>
            </div>
          ))}
        </div>
        <div class="rl-carousel-footer">
          <div class="rl-dots" aria-hidden="true">
            {projectScreens.lasalle.map((_: string, i: number) => (
              <button class={`rl-dot${i === 0 ? " rl-dot--active" : ""}`} data-index={i}></button>
            ))}
          </div>
          {projectScreens.lasalle.length > 1 && (
            <div class="rl-arrows">
              <button class="rl-arrow rl-arrow--prev" aria-label="Image précédente">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M15 18l-6-6 6-6"/></svg>
              </button>
              <button class="rl-arrow rl-arrow--next" aria-label="Image suivante">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M9 18l6-6-6-6"/></svg>
              </button>
            </div>
          )}
        </div>
      </div>
    </article>

  </div>
</section>

<!-- ══ LIGHTBOX ══ -->
<div class="lb" id="lightbox" role="dialog" aria-modal="true" aria-label="Aperçu image" hidden>
  <div class="lb-backdrop"></div>
  <button class="lb-close" aria-label="Fermer">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><path d="M18 6 6 18M6 6l12 12"/></svg>
  </button>
  <button class="lb-nav lb-nav--prev" aria-label="Image précédente">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24"><path d="M15 18l-6-6 6-6"/></svg>
  </button>
  <div class="lb-stage">
    <div class="lb-frame-bar" aria-hidden="true"><span></span><span></span><span></span></div>
    <img class="lb-img" src="" alt="" />
  </div>
  <button class="lb-nav lb-nav--next" aria-label="Image suivante">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24"><path d="M9 18l6-6-6-6"/></svg>
  </button>
  <div class="lb-counter" aria-live="polite"></div>
</div>

<!-- ══ CTA ══ -->
<section class="rcta" aria-label="Contact">
  <div class="rcta-img" aria-hidden="true"></div>
  <div class="rcta-overlay" aria-hidden="true"></div>
  <div class="container">
    <div class="rcta-inner rl-reveal">
    <p class="rcta-eyebrow">{r.ctaEyebrow}</p>
    <h2 class="rcta-title">{r.ctaTitle}</h2>
    <p class="rcta-sub">{r.ctaSub}</p>
    <a href={`/${lang}/contact`} class="btn-hero">
      {r.cta}
      <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="18" height="18"><path d="M4 10h12M11 5l5 5-5 5"/></svg>
    </a>
    </div>
  </div>
</section>

<style>
/* ══ ANIMATIONS ══ */
@keyframes rh-in {
  from { opacity: 0; transform: translateY(18px); }
  to   { opacity: 1; transform: translateY(0); }
}
.rh-anim {
  opacity: 0;
  animation: rh-in 0.65s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  animation-delay: var(--d, 0s);
}
@keyframes rl-in {
  from { opacity: 0; transform: translateY(32px); }
  to   { opacity: 1; transform: translateY(0); }
}
.rl-reveal {
  opacity: 0;
  transition: none;
}
.rl-reveal.visible {
  animation: rl-in 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

/* Ligne décorative animée sous le titre du projet */
.rl-name {
  position: relative;
  display: inline-block;
}
.rl-name::after {
  content: "";
  position: absolute;
  left: 0; bottom: -4px;
  height: 2px;
  width: 0;
  background: linear-gradient(90deg, var(--color-accent), var(--color-primary));
  transition: width 0.55s cubic-bezier(0.22, 1, 0.36, 1);
}
.rl-reveal.visible .rl-name::after {
  width: 100%;
  transition-delay: 0.35s;
}

/* ══ HERO ══ */
.rh {
  position: relative;
  overflow: hidden;
  padding: 6rem 0 5rem;
  color: #fff;
}
.rh-bg {
  position: absolute;
  inset: 0;
  background-image: url('/images/hero/Testimony%203.jpg');
  background-size: cover;
  background-position: center 30%;
  z-index: 0;
}
.rh-bg::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(
    110deg,
    rgba(2, 33, 121, 0.93) 0%,
    rgba(2, 33, 121, 0.78) 55%,
    rgba(164, 37, 147, 0.28) 100%
  );
}
.rh-inner {
  position: relative;
  z-index: 1;
  max-width: 640px;
}
.rh-eyebrow {
  display: inline-block;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.65);
  margin-bottom: 1.1rem;
}
.rh-title {
  font-size: clamp(2rem, 4.5vw, 3.2rem);
  font-weight: 800;
  line-height: 1.12;
  letter-spacing: -0.02em;
  color: #fff;
  margin: 0 0 1.25rem;
}
.rh-sub {
  font-size: clamp(0.97rem, 2vw, 1.1rem);
  color: rgba(255,255,255,0.82);
  line-height: 1.75;
  margin: 0 0 2.5rem;
}
.rh-stats {
  list-style: none;
  display: flex;
  gap: 0;
  border-top: 1px solid rgba(255,255,255,0.18);
  padding-top: 0;
}
.rh-stats li {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
  padding: 1.5rem 2.5rem 0 0;
  margin-right: 2.5rem;
  border-right: 1px solid rgba(255,255,255,0.15);
}
.rh-stats li:last-child { border-right: none; margin-right: 0; }
.rh-stat-val {
  font-size: 1.75rem;
  font-weight: 800;
  color: #fff;
  letter-spacing: -0.02em;
  line-height: 1;
}
.rh-stat-lbl {
  font-size: 0.78rem;
  color: rgba(255,255,255,0.62);
}

/* ══ PROJETS ══ */
.rl-projects {
  padding: 5rem 0 2rem;
}
.rl-item {
  display: grid;
  grid-template-columns: 380px 1fr;
  gap: 4.5rem;
  align-items: start;
  padding: 4rem 0;
  border-bottom: 1px solid var(--color-border);
}
.rl-item:first-child { padding-top: 0; }
.rl-item:last-child { border-bottom: none; }
.rl-item--reverse {
  grid-template-columns: 1fr 380px;
}
.rl-item--reverse .rl-info { order: 2; }
.rl-item--reverse .rl-carousel { order: 1; }

/* Info */
.rl-num {
  display: block;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  color: var(--color-text-secondary);
  opacity: 0.4;
  margin-bottom: 1.25rem;
}
.rl-sector {
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.09em;
  color: var(--color-accent);
  margin-bottom: 0.6rem;
}
.rl-name {
  font-size: clamp(1.4rem, 2.5vw, 1.8rem);
  font-weight: 700;
  line-height: 1.2;
  letter-spacing: -0.01em;
  margin-bottom: 0.35rem;
  color: var(--color-text);
}
.rl-client {
  font-size: 0.85rem;
  color: var(--color-text-secondary);
  margin-bottom: 1.25rem;
}
.rl-desc {
  font-size: 0.95rem;
  line-height: 1.8;
  color: var(--color-text-secondary);
  margin-bottom: 1.5rem;
}
.rl-tags {
  list-style: none;
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
  margin-bottom: 1.75rem;
}
.rl-tags li {
  font-size: 0.75rem;
  font-weight: 600;
  padding: 0.28rem 0.75rem;
  border-radius: 20px;
  border: 1px solid var(--color-border);
  color: var(--color-text-secondary);
  background: var(--color-bg-secondary);
}
.rl-kpi {
  display: inline-flex;
  align-items: baseline;
  gap: 0.55rem;
  padding: 0.9rem 1.25rem;
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border);
  border-radius: 10px;
  margin-bottom: 1.5rem;
}
.rl-kpi-val {
  font-size: 1.65rem;
  font-weight: 800;
  color: var(--color-primary);
  letter-spacing: -0.02em;
  line-height: 1;
}
.rl-kpi-lbl {
  font-size: 0.82rem;
  color: var(--color-text-secondary);
}
.rl-link {
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  font-size: 0.88rem;
  font-weight: 600;
  color: var(--color-accent);
  text-decoration: none;
  border-bottom: 1.5px solid currentColor;
  padding-bottom: 0.1rem;
  transition: gap 0.2s;
}
.rl-link:hover { gap: 0.7rem; }

/* Carousel */
.rl-carousel {
  position: relative;
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid var(--color-border);
  background: var(--color-bg-secondary);
  box-shadow: 0 12px 40px rgba(2,33,121,0.09);
}
.rl-carousel-track {
  display: flex;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scrollbar-width: none;
  -ms-overflow-style: none;
}
.rl-carousel-track::-webkit-scrollbar { display: none; }
.rl-slide {
  flex: 0 0 100%;
  scroll-snap-align: start;
  position: relative;
}
.rl-bar {
  height: 26px;
  background: var(--color-bg-secondary);
  border-bottom: 1px solid var(--color-border);
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 0 10px;
}
.rl-bar span { width: 8px; height: 8px; border-radius: 50%; }
.rl-bar span:nth-child(1) { background: #ff5f57; }
.rl-bar span:nth-child(2) { background: #febc2e; }
.rl-bar span:nth-child(3) { background: #28c840; }

/* Zoom button */
.rl-zoom-btn {
  display: block;
  width: 100%;
  padding: 0;
  border: none;
  background: none;
  cursor: zoom-in;
  position: relative;
  overflow: hidden;
}
.rl-zoom-btn img { width: 100%; height: auto; display: block; transition: transform 0.45s cubic-bezier(0.22,1,0.36,1); }
.rl-zoom-btn:hover img { transform: scale(1.04); }
.rl-zoom-hint {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(2,33,121,0.0);
  color: #fff;
  opacity: 0;
  transition: opacity 0.3s, background 0.3s;
  pointer-events: none;
}
.rl-zoom-hint svg { filter: drop-shadow(0 2px 6px rgba(0,0,0,0.4)); transform: scale(0.8); transition: transform 0.3s; }
.rl-zoom-btn:hover .rl-zoom-hint { opacity: 1; background: rgba(2,33,121,0.22); }
.rl-zoom-btn:hover .rl-zoom-hint svg { transform: scale(1); }

/* Footer : dots + arrows */
.rl-carousel-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.55rem 0.75rem;
  background: var(--color-bg-secondary);
  border-top: 1px solid var(--color-border);
  min-height: 40px;
}
.rl-dots {
  display: flex;
  gap: 6px;
  flex: 1;
  justify-content: center;
}
.rl-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  border: none;
  background: var(--color-border);
  cursor: pointer;
  padding: 0;
  transition: background 0.2s, transform 0.25s, width 0.25s;
}
.rl-dot--active {
  background: var(--color-accent);
  width: 18px;
  border-radius: 3px;
}
.rl-arrows {
  display: flex;
  gap: 4px;
}
.rl-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28px; height: 28px;
  border-radius: 6px;
  border: 1px solid var(--color-border);
  background: var(--color-bg);
  color: var(--color-text);
  cursor: pointer;
  transition: background 0.2s, border-color 0.2s, color 0.2s;
}
.rl-arrow:hover { background: var(--color-accent); border-color: var(--color-accent); color: #fff; }
.rl-arrow:disabled { opacity: 0.3; cursor: default; }

/* ══ LIGHTBOX ══ */
.lb {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 1.5rem;
}
.lb[hidden] { display: none; }
.lb-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(2, 5, 30, 0.92);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  cursor: pointer;
}
@keyframes lb-in {
  from { opacity: 0; transform: scale(0.92) translateY(12px); }
  to   { opacity: 1; transform: scale(1)    translateY(0); }
}
.lb-stage {
  position: relative;
  z-index: 2;
  max-width: min(90vw, 1100px);
  width: 100%;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 32px 80px rgba(0,0,0,0.6);
  animation: lb-in 0.38s cubic-bezier(0.22,1,0.36,1) both;
}
.lb-frame-bar {
  height: 28px;
  background: #1e2030;
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 0 12px;
}
.lb-frame-bar span { width: 9px; height: 9px; border-radius: 50%; }
.lb-frame-bar span:nth-child(1) { background: #ff5f57; }
.lb-frame-bar span:nth-child(2) { background: #febc2e; }
.lb-frame-bar span:nth-child(3) { background: #28c840; }
.lb-img {
  width: 100%;
  height: auto;
  display: block;
  background: #0d1023;
  transition: opacity 0.2s;
}
.lb-img.switching { opacity: 0; }
.lb-close {
  position: absolute;
  top: 1.25rem; right: 1.25rem;
  z-index: 3;
  width: 40px; height: 40px;
  border-radius: 50%;
  border: 1.5px solid rgba(255,255,255,0.25);
  background: rgba(255,255,255,0.08);
  color: #fff;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: background 0.2s, border-color 0.2s;
}
.lb-close:hover { background: rgba(255,255,255,0.18); border-color: rgba(255,255,255,0.5); }
.lb-nav {
  position: relative;
  z-index: 2;
  width: 48px; height: 48px;
  border-radius: 50%;
  border: 1.5px solid rgba(255,255,255,0.2);
  background: rgba(255,255,255,0.07);
  color: #fff;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  transition: background 0.2s, border-color 0.2s, transform 0.2s;
}
.lb-nav:hover { background: rgba(255,255,255,0.18); border-color: rgba(255,255,255,0.45); transform: scale(1.08); }
.lb-nav:disabled { opacity: 0.2; cursor: default; transform: none; }
.lb-counter {
  position: absolute;
  bottom: 1.5rem;
  left: 50%;
  transform: translateX(-50%);
  z-index: 3;
  font-size: 0.8rem;
  color: rgba(255,255,255,0.55);
  letter-spacing: 0.05em;
  pointer-events: none;
}

/* ══ CTA ══ */
.rcta {
  position: relative;
  overflow: hidden;
  padding: 5.5rem 0;
  color: #fff;
  margin-top: 1rem;
}
.rcta-img {
  position: absolute;
  inset: 0;
  background-image: url('/images/hero/Testimony%201.jpg');
  background-size: cover;
  background-position: center;
  z-index: 0;
}
.rcta-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    110deg,
    rgba(2, 33, 121, 0.95) 0%,
    rgba(2, 33, 121, 0.80) 60%,
    rgba(164, 37, 147, 0.50) 100%
  );
  z-index: 1;
}
.rcta-inner {
  position: relative;
  z-index: 2;
  max-width: 580px;
  margin-left: 4rem;
  text-align: left;
}
.rcta-eyebrow {
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.6);
  margin-bottom: 1rem;
}
.rcta-title {
  font-size: clamp(1.7rem, 4vw, 2.5rem);
  font-weight: 800;
  line-height: 1.15;
  letter-spacing: -0.02em;
  color: #fff;
  margin-bottom: 1rem;
}
.rcta-sub {
  font-size: 1rem;
  line-height: 1.75;
  color: rgba(255,255,255,0.78);
  margin-bottom: 2.25rem;
}
.btn-hero {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.9rem 1.75rem;
  border-radius: 50px;
  background: #fff;
  color: var(--color-primary);
  font-weight: 700;
  font-size: 0.95rem;
  text-decoration: none;
  box-shadow: 0 8px 28px rgba(0,0,0,0.22);
  transition: transform 0.22s ease, box-shadow 0.22s ease;
  white-space: nowrap;
}
.btn-hero:hover { transform: translateY(-3px); box-shadow: 0 14px 36px rgba(0,0,0,0.28); }
.btn-hero svg { transition: transform 0.22s ease; }
.btn-hero:hover svg { transform: translateX(4px); }

/* ══ RESPONSIVE ══ */
@media (max-width: 900px) {
  .rl-item { grid-template-columns: 1fr; gap: 2.5rem; }
  .rl-item--reverse .rl-info { order: 1; }
  .rl-item--reverse .rl-carousel { order: 2; }
}
@media (max-width: 600px) {
  .rh { padding: 4rem 0 3.5rem; }
  .rh-bg { background-position: 70% center; }
  .rh-stats { flex-wrap: wrap; gap: 0; }
  .rh-stats li { padding: 1.25rem 1.5rem 0 0; margin-right: 1.5rem; }
  .rcta { padding: 4rem 0; }
  .rcta-inner { margin-left: 0; }
}
</style>

<script is:inline>
(function () {

  /* ══ CAROUSELS ══ */
  document.querySelectorAll("[data-carousel]").forEach(function (carousel) {
    var track   = carousel.querySelector(".rl-carousel-track");
    var dots    = Array.from(carousel.querySelectorAll(".rl-dot"));
    var btnPrev = carousel.querySelector(".rl-arrow--prev");
    var btnNext = carousel.querySelector(".rl-arrow--next");
    var slides  = Array.from(carousel.querySelectorAll(".rl-slide"));
    if (!track) return;

    function currentIdx() { return Math.round(track.scrollLeft / track.offsetWidth); }
    function goTo(i) { track.scrollTo({ left: i * track.offsetWidth, behavior: "smooth" }); }
    function syncUI() {
      var i = currentIdx();
      dots.forEach(function (d, j) { d.classList.toggle("rl-dot--active", j === i); });
      if (btnPrev) btnPrev.disabled = i === 0;
      if (btnNext) btnNext.disabled = i === slides.length - 1;
    }

    track.addEventListener("scroll", syncUI, { passive: true });
    dots.forEach(function (dot, i) { dot.addEventListener("click", function () { goTo(i); }); });
    if (btnPrev) btnPrev.addEventListener("click", function () { goTo(Math.max(0, currentIdx() - 1)); });
    if (btnNext) btnNext.addEventListener("click", function () { goTo(Math.min(slides.length - 1, currentIdx() + 1)); });

    var tx = 0;
    track.addEventListener("touchstart", function (e) { tx = e.touches[0].clientX; }, { passive: true });
    track.addEventListener("touchend", function (e) {
      var diff = tx - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) goTo(diff > 0 ? Math.min(slides.length-1, currentIdx()+1) : Math.max(0, currentIdx()-1));
    }, { passive: true });

    syncUI();

    carousel._lb = slides.map(function (sl) {
      var img = sl.querySelector("img"); return img ? img.src : "";
    }).filter(Boolean);
  });

  /* ══ LIGHTBOX ══ */
  var lb      = document.getElementById("lightbox");
  var lbImg   = lb && lb.querySelector(".lb-img");
  var lbCloseBtns = lb ? lb.querySelectorAll(".lb-close, .lb-backdrop") : [];
  var lbPrev  = lb && lb.querySelector(".lb-nav--prev");
  var lbNext  = lb && lb.querySelector(".lb-nav--next");
  var lbCount = lb && lb.querySelector(".lb-counter");
  var lbSrcs  = [], lbIdx = 0;

  function lbShow() {
    if (!lbImg) return;
    lbImg.classList.add("switching");
    setTimeout(function () {
      lbImg.src = lbSrcs[lbIdx];
      lbImg.classList.remove("switching");
    }, 160);
    if (lbCount) lbCount.textContent = lbSrcs.length > 1 ? (lbIdx + 1) + " / " + lbSrcs.length : "";
    if (lbPrev) { lbPrev.disabled = lbIdx === 0; lbPrev.style.visibility = lbSrcs.length > 1 ? "" : "hidden"; }
    if (lbNext) { lbNext.disabled = lbIdx === lbSrcs.length - 1; lbNext.style.visibility = lbSrcs.length > 1 ? "" : "hidden"; }
  }
  function lbOpen(srcs, idx) {
    lbSrcs = srcs; lbIdx = idx;
    lb.removeAttribute("hidden");
    document.body.style.overflow = "hidden";
    lbShow();
  }
  function lbCloseF() {
    lb.setAttribute("hidden", "");
    document.body.style.overflow = "";
  }

  lbCloseBtns.forEach(function (el) { el.addEventListener("click", lbCloseF); });
  if (lbPrev) lbPrev.addEventListener("click", function () { if (lbIdx > 0) { lbIdx--; lbShow(); } });
  if (lbNext) lbNext.addEventListener("click", function () { if (lbIdx < lbSrcs.length - 1) { lbIdx++; lbShow(); } });

  document.addEventListener("keydown", function (e) {
    if (!lb || lb.hasAttribute("hidden")) return;
    if (e.key === "Escape") lbCloseF();
    if (e.key === "ArrowLeft"  && lbIdx > 0)                  { lbIdx--; lbShow(); }
    if (e.key === "ArrowRight" && lbIdx < lbSrcs.length - 1)  { lbIdx++; lbShow(); }
  });

  document.querySelectorAll(".rl-zoom-btn").forEach(function (btn) {
    btn.addEventListener("click", function () {
      var carousel = btn.closest("[data-carousel]");
      var srcs = carousel && carousel._lb;
      if (!srcs || !srcs.length) return;
      lbOpen(srcs, parseInt(btn.getAttribute("data-idx") || "0", 10));
    });
  });

  /* ══ COMPTEURS STATS ══ */
  function animateCount(el, target, dur) {
    var t0 = performance.now(), big = target >= 1000;
    (function step(ts) {
      var p = Math.min((ts - t0) / dur, 1), ease = 1 - Math.pow(1 - p, 3);
      el.textContent = big ? Math.round(ease * target).toLocaleString("fr-FR").replace(/ /g, " ") : String(Math.round(ease * target));
      if (p < 1) requestAnimationFrame(step);
    })(performance.now());
  }
  var statsObs = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (!e.isIntersecting) return;
      e.target.querySelectorAll("[data-count]").forEach(function (el) { animateCount(el, +el.getAttribute("data-count"), 1400); });
      statsObs.unobserve(e.target);
    });
  }, { threshold: 0.4 });
  var sl = document.querySelector(".rh-stats");
  if (sl) statsObs.observe(sl);

  /* ══ SCROLL REVEAL ══ */
  var revObs = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add("visible"); revObs.unobserve(e.target); } });
  }, { threshold: 0.1 });
  document.querySelectorAll(".rl-reveal").forEach(function (el) { revObs.observe(el); });

})();
</script>
