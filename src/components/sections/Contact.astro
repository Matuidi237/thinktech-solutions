  { flag: "🇪🇷", name: lang === "fr" ? "Érythrée"             : "Eritrea",                  code: "+291" },
  { flag: "🇪🇹", name: lang === "fr" ? "Éthiopie"             : "Ethiopia",                 code: "+251" },
  { flag: "🇬🇦", name: "Gabon",                                                              code: "+241" },
  { flag: "🇬🇲", name: lang === "fr" ? "Gambie"               : "Gambia",                   code: "+220" },
  { flag: "🇬🇭", name: "Ghana",                                                              code: "+233" },
