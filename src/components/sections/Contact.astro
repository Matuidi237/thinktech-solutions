const intlCountries = [
  { flag: "🇩🇪", name: lang === "fr" ? "Allemagne"            : "Germany",                  code: "+49"  },
  { flag: "🇧🇪", name: lang === "fr" ? "Belgique"             : "Belgium",                  code: "+32"  },
  { flag: "🇨🇦", name: "Canada",                                                             code: "+1"   },
  { flag: "🇫🇷", name: "France",                                                             code: "+33"  },
  { flag: "🇬🇧", name: lang === "fr" ? "Royaume-Uni"          : "United Kingdom",           code: "+44"  },
  { flag: "🇨🇭", name: lang === "fr" ? "Suisse"               : "Switzerland",              code: "+41"  },
  { flag: "🇺🇸", name: lang === "fr" ? "États-Unis"           : "United States",            code: "+1"   },
];
---

<section id="contact" class="contact" aria-labelledby="contact-title">
  <div class="circle-deco contact-circle-1" aria-hidden="true"></div>
  <div class="circle-deco circle-delay circle-fill contact-circle-2" aria-hidden="true"></div>
  <div class="container">
    <div class="contact-intro reveal">
      <p class="eyebrow">{t.contact.eyebrow ?? "Contact"}</p>
      <h1 id="contact-title">{t.contact.title}</h1>
      <p class="contact-subtitle">{t.contact.subtitle}</p>
    </div>

    <form id="demo-form" class="contact-form reveal" method="post" action="/api/contact" novalidate>
      <div class="form-row">
        <div class="form-field">
          <label for="name">{f.name} *</label>
          <input type="text" id="name" name="name" required autocomplete="name" minlength="2" />
        </div>
        <div class="form-field">
          <label for="org">{f.organization} *</label>
          <input type="text" id="org" name="organization" required autocomplete="organization" minlength="2" />
        </div>
      </div>

      <div class="form-row">
        <div class="form-field">
          <label for="email">{f.email} *</label>
          <input type="email" id="email" name="email" required autocomplete="email" />
        </div>
        <div class="form-field">
          <label for="phone">{f.phone} *</label>
          <div class="phone-row">
            <select id="country-code" name="countryCode" class="country-select" aria-label={lang === "fr" ? "Indicatif pays" : "Country code"}>
              <optgroup label={lang === "fr" ? "── Afrique ──" : "── Africa ──"}>
                {africaCountries.map(c => (
                  <option value={c.code} selected={c.code === "+237" && c.name.includes("Cameroun") || c.code === "+237" && c.name.includes("Cameroon") ? true : undefined}>
                    {c.flag} {c.name} ({c.code})
                  </option>
                ))}
              </optgroup>
              <optgroup label={lang === "fr" ? "── International ──" : "── International ──"}>
                {intlCountries.map(c => (
                  <option value={c.code}>{c.flag} {c.name} ({c.code})</option>
                ))}
              </optgroup>
            </select>
            <div class="phone-input-wrap">
              <span class="phone-prefix" id="phone-prefix">+237</span>
              <input type="tel" id="phone" name="phone" required autocomplete="tel"
                placeholder="6XX XXX XXX" pattern="^[0-9\s\-]{5,15}$" />
            </div>
          </div>
        </div>
      </div>

      <div class="form-field">
        <label for="org-type">{f.orgType} *</label>
        <select id="org-type" name="orgType" required>
          <option value=""></option>
          {f.orgTypeOptions.map((opt: string) => <option value={opt}>{opt}</option>)}
        </select>
      </div>

      <div class="form-field">
        <label for="need">{f.need} *</label>
        <textarea id="need" name="need" required rows="5" minlength="10" placeholder={f.needPlaceholder}></textarea>
      </div>

      <input type="text" name="website" class="honeypot" tabindex="-1" autocomplete="off" aria-hidden="true" />
      <input type="hidden" name="loadedAt" id="loadedAt" />

      <div class="form-submit-row">
        <button type="submit" class="btn btn-primary">{f.submit}</button>
        <span class="form-note">{t.contact.formNote ?? ""}</span>
      </div>
      <p class="form-feedback" role="status" aria-live="polite" data-success={f.success} data-error={f.error}></p>
    </form>
  </div>
</section>

<style>
  .contact { position: relative; overflow: hidden; padding-top: 1rem; }
  .contact-circle-1 { top: -60px; right: 10%; width: 220px; height: 220px; }
  .contact-circle-2 { bottom: 5%; left: -70px; width: 240px; height: 240px; }
  .contact .container { position: relative; z-index: 1; }

  .contact-intro { max-width: 640px; margin: 0 auto 2.5rem; text-align: center; }
  .contact-subtitle { margin-top: 0.75rem; font-size: 1.1rem; }

  .contact-form {
    max-width: 700px;
    margin: 0 auto;
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 2.5rem;
    box-shadow: 0 30px 60px rgba(2, 33, 121, 0.08);
  }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .form-field { margin-bottom: 1.25rem; display: flex; flex-direction: column; gap: 0.4rem; }
  .form-field label { font-weight: 500; font-size: 0.9rem; }
  .form-field input, .form-field select, .form-field textarea {
    padding: 0.75rem 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg);
    color: var(--color-text);
    font-family: inherit;
    font-size: 0.95rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .form-field input:focus, .form-field select:focus, .form-field textarea:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(164, 37, 147, 0.15);
  }

  /* Phone row */
  .phone-row { display: flex; gap: 0; align-items: stretch; }
  .country-select {
    flex: 0 0 auto;
    width: 210px;
    border-radius: 8px 0 0 8px;
    border-right: none !important;
    font-size: 0.88rem;
    padding: 0.75rem 0.6rem;
    background: var(--color-bg-secondary);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    cursor: pointer;
    appearance: auto;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .country-select:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(164, 37, 147, 0.15);
    z-index: 1;
  }
  .phone-input-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    border: 1px solid var(--color-border);
    border-left: none;
    border-radius: 0 8px 8px 0;
    background: var(--color-bg);
    overflow: hidden;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .phone-input-wrap:focus-within {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(164, 37, 147, 0.15);
  }
  .phone-prefix {
    padding: 0 0.6rem 0 0.75rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary);
    white-space: nowrap;
    border-right: 1px solid var(--color-border);
    line-height: 1;
    user-select: none;
  }
  .phone-input-wrap input[type="tel"] {
    flex: 1;
    border: none !important;
    box-shadow: none !important;
    border-radius: 0;
    padding: 0.75rem 0.9rem;
    background: transparent;
    min-width: 0;
  }
  .phone-input-wrap input[type="tel"]:focus { outline: none; }

  @media (max-width: 480px) {
    .phone-row { flex-direction: column; gap: 0.5rem; }
    .country-select { width: 100%; border-radius: 8px; border-right: 1px solid var(--color-border) !important; }
    .phone-input-wrap { border-left: 1px solid var(--color-border); border-radius: 8px; }
  }

  .honeypot { position: absolute; left: -9999px; width: 1px; height: 1px; opacity: 0; }

  .form-submit-row { display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap; margin-top: 0.5rem; }
  .contact-form .btn-primary { padding: 0.85rem 2rem; }
  .form-note { font-size: 0.85rem; color: var(--color-text-secondary); }
  .form-feedback { margin-top: 1.25rem; font-weight: 500; }
  .form-feedback.success { color: var(--color-success); }
  .form-feedback.error { color: #C0392B; }

  @media (max-width: 700px) {
    .form-row { grid-template-columns: 1fr; }
    .contact-form { padding: 1.75rem 1.5rem; }
  }
</style>

<script>
  document.getElementById("loadedAt")?.setAttribute("value", String(Date.now()));

  const countrySelect = document.getElementById("country-code") as HTMLSelectElement | null;
  const phonePrefix  = document.getElementById("phone-prefix");
  const phoneInput   = document.getElementById("phone") as HTMLInputElement | null;
  const demoForm     = document.getElementById("demo-form") as HTMLFormElement | null;

  function updatePrefix() {
    if (!countrySelect || !phonePrefix) return;
    const selected = countrySelect.options[countrySelect.selectedIndex];
    const label = (selected.textContent ?? "").trim();
    const flag = [...label].slice(0, 2).join(""); // first 2 chars = flag emoji
    phonePrefix.textContent = `${flag} ${countrySelect.value}`;
  }

  updatePrefix();
  countrySelect?.addEventListener("change", updatePrefix);

  demoForm?.addEventListener("submit", () => {
    if (phoneInput && countrySelect) {
      const raw = phoneInput.value.trim().replace(/^0+/, "");
      phoneInput.value = countrySelect.value + raw;
    }
  });
</script>
<script is:inline src="/scripts/form-validation.js"></script>
