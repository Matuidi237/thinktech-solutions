  { flag: "🇬🇶", name: lang === "fr" ? "Guinée équatoriale"   : "Equatorial Guinea",         code: "+240" },
  { flag: "🇬🇼", name: lang === "fr" ? "Guinée-Bissau"        : "Guinea-Bissau",            code: "+245" },
  { flag: "🇰🇪", name: "Kenya",                                                              code: "+254" },
  { flag: "🇱🇸", name: "Lesotho",                                                            code: "+266" },
  { flag: "🇱🇷", name: "Liberia",                                                            code: "+231" },
  { flag: "🇱🇾", name: lang === "fr" ? "Libye"                : "Libya",                    code: "+218" },
  { flag: "🇲🇬", name: "Madagascar",                                                         code: "+261" },
