  { flag: "🇸🇸", name: lang === "fr" ? "Soudan du Sud"        : "South Sudan",              code: "+211" },
  { flag: "🇹🇿", name: lang === "fr" ? "Tanzanie"             : "Tanzania",                 code: "+255" },
  { flag: "🇹🇩", name: lang === "fr" ? "Tchad"                : "Chad",                     code: "+235" },
  { flag: "🇹🇬", name: "Togo",                                                              code: "+228" },
  { flag: "🇹🇳", name: lang === "fr" ? "Tunisie"              : "Tunisia",                  code: "+216" },
  { flag: "🇿🇲", name: lang === "fr" ? "Zambie"               : "Zambia",                   code: "+260" },
  { flag: "🇿🇼", name: "Zimbabwe",                                                           code: "+263" },
