---
import type { Lang } from "../../i18n/utils";
import { useTranslations, getOtherLang } from "../../i18n/utils";

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const otherLang = getOtherLang(lang);

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const navItems = [
  { href: `/${lang}`, label: t.nav.home },
  { href: `/${lang}/about`, label: t.nav.about },
  { href: `/${lang}/services`, label: t.nav.services },
  { href: `/${lang}/realisations`, label: t.nav.realisations },
  { href: `/${lang}/actualites`, label: t.nav.news },
  { href: `/${lang}/contact`, label: t.nav.contact }
];
---

<header class="site-header" role="banner">
  <nav class="navbar" aria-label="Navigation principale">
    <div class="nav-left">
      <a href={`/${lang}/`} class="logo" aria-label="ThinkTech Solutions, retour à l'accueil">
        <img src="/logo.svg" alt="ThinkTech Solutions" width="44" height="44" />
        <span class="wordmark">ThinkTech<span class="wordmark-accent">Solutions</span></span>
      </a>
      <ul class="nav-links">
        {navItems.map((item) => (
          <li>
            <a href={item.href} aria-current={currentPath === item.href.replace(/\/$/, "") ? "page" : undefined}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="nav-controls">
      <a href={`/${otherLang}/`} class="lang-switch" aria-label="Changer de langue">{otherLang.toUpperCase()}</a>
      <a href={`/${lang}/contact`} class="btn btn-primary">{t.nav.cta}</a>
      <button id="burger" class="burger" aria-label="Ouvrir le menu" aria-expanded="false">☰</button>
    </div>
  </nav>
</header>

<style>
  .site-header { position: sticky; top: 0; z-index: 100; }
  .navbar { display: flex; align-items: center; justify-content: space-between; padding: 1rem 2.5rem 1rem 3rem; max-width: 100%; }

  .nav-left { display: flex; align-items: center; gap: 2rem; }
  .logo { display: flex; align-items: center; gap: 0.65rem; flex-shrink: 0; text-decoration: none; }
  .logo img { width: 44px; height: 44px; }
  .wordmark { font-size: 1.15rem; font-weight: 600; color: var(--color-text); line-height: 1; white-space: nowrap; }
  .wordmark-accent { color: var(--color-accent); display: block; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; margin-top: 0.1rem; }

  .nav-links { display: flex; gap: 1.75rem; list-style: none; margin: 0; padding: 0; }
  .nav-links a { font-weight: 500; font-size: 0.95rem; padding-bottom: 0.3rem; border-bottom: 2px solid transparent; }
  .nav-links a:hover { color: var(--color-accent); }
  .nav-links a[aria-current="page"] { color: var(--color-accent); border-bottom-color: var(--color-accent); }

  .nav-controls { display: flex; align-items: center; gap: 0.75rem; flex-shrink: 0; }
  .lang-switch { background: none; border: 1px solid var(--color-border); border-radius: 6px; padding: 0.35rem 0.6rem; cursor: pointer; color: var(--color-text); font-size: 0.85rem; text-decoration: none; }
  .burger { display: none; background: none; border: none; font-size: 1.5rem; cursor: pointer; color: var(--color-text); }

  @media (max-width: 1024px) {
    .navbar { padding: 1rem 1.5rem; }
  }

  @media (max-width: 768px) {
    .navbar { padding: 0.85rem 1.25rem; }
    .nav-links, .nav-controls .btn-primary { display: none; }
    .burger { display: block; }
    .navbar.menu-open .nav-links {
      display: flex;
      flex-direction: column;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--color-bg);
      padding: 1.5rem 1.25rem;
      gap: 1.25rem;
      border-bottom: 1px solid var(--color-border);
      box-shadow: 0 8px 24px rgba(0,0,0,0.08);
      z-index: 99;
    }
    .navbar.menu-open .nav-links a { font-size: 1.05rem; }
  }
</style>

<script is:inline>
  document.getElementById("burger")?.addEventListener("click", function () {
    const nav = this.closest(".navbar");
    const expanded = this.getAttribute("aria-expanded") === "true";
    this.setAttribute("aria-expanded", String(!expanded));
    nav.classList.toggle("menu-open");
  });
</script>
