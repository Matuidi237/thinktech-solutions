---

<footer class="site-footer" role="contentinfo">
  <div class="circle-deco circle-fill footer-circle-1" aria-hidden="true"></div>
  <div class="circle-deco footer-circle-2" aria-hidden="true"></div>

  <div class="container footer-grid">
    <div class="footer-brand">
      <a href={`/${lang}/`} class="footer-logo">
        <img src="/images/brand/logo-white.webp" alt="ThinkTech Solutions" width="54" height="54" />
        <span>ThinkTech<small>Solutions</small></span>
      </a>
      <p>{t.footer.tagline}</p>
      <ul class="social-links">
        {socials.map((s) => (
          <li>
            <a href={s.href} aria-label={s.name}>
              <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d={s.path} /></svg>
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="footer-col">
      <h4>{t.footer.navTitle}</h4>
      <ul>
        <li><a href={`/${lang}/`}>{t.nav.home}</a></li>
        <li><a href={`/${lang}/about`}>{t.nav.about}</a></li>
        <li><a href={`/${lang}/services`}>{t.nav.services}</a></li>
        <li><a href={`/${lang}/realisations`}>{t.nav.realisations}</a></li>
        <li><a href={`/${lang}/contact`}>{t.nav.contact}</a></li>
        <li><a href={`/${lang}/actualites`}>{t.nav.news}</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>{t.footer.contactTitle}</h4>
      <address>
        <a href="mailto:contact@thinktech-solutions.com">contact@thinktech-solutions.com</a>
        <a href="tel:+237689357969">+237 689 35 79 69</a>
        <span>Douala, Cameroun</span>
      </address>
    </div>
  </div>

  <div class="container footer-bottom">
    <span><a href={`/${lang}/legal`}>{t.footer.legal}</a> · <a href={`/${lang}/privacy`}>{t.footer.privacy}</a></span>
    <span>{t.footer.copyright}</span>
  </div>
</footer>

<style>
  .site-footer { position: relative; overflow: hidden; padding: 4rem 0 1.5rem; margin-top: 2rem; }
  .footer-circle-1 { top: -80px; left: -60px; width: 220px; height: 220px; color: #fff; opacity: 0.06; }
  .footer-circle-2 { bottom: -60px; right: 6%; width: 170px; height: 170px; color: #fff; opacity: 0.1; }

  .footer-grid { position: relative; z-index: 1; display: grid; grid-template-columns: 1.6fr 1fr 1fr; gap: 3rem; align-items: start; }

  .footer-brand { padding-right: 1rem; }
  .footer-logo { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; }
  .footer-logo img { width: 54px; height: 54px; }
  .footer-logo span { font-size: 1.2rem; font-weight: 700; color: #fff; line-height: 1.1; }
  .footer-logo small { display: block; font-size: 0.65rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(255,255,255,0.7); margin-top: 0.15rem; }
  .footer-brand p { max-width: 280px; margin-bottom: 1.5rem; }

  .social-links { display: flex; gap: 0.65rem; list-style: none; }
  .social-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: rgba(255,255,255,0.08);
    color: #fff;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }
  .social-links a:hover { background: var(--color-accent); transform: translateY(-2px); }

  .footer-col h4 { color: #fff; margin-bottom: 1.1rem; font-size: 1rem; position: relative; padding-bottom: 0.6rem; }
  .footer-col h4::after { content: ""; position: absolute; left: 0; bottom: 0; width: 28px; height: 2px; background: var(--color-accent-light); }
  .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 0.65rem; }
  .footer-col a, .footer-col address, .footer-brand p { color: rgba(255,255,255,0.7); }
  .footer-col a:hover { color: #fff; }
  .footer-col address { display: flex; flex-direction: column; gap: 0.65rem; font-style: normal; }

  .footer-bottom { position: relative; z-index: 1; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem; margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid rgba(255,255,255,0.12); font-size: 0.85rem; color: rgba(255,255,255,0.55); }
  .footer-bottom a { color: rgba(255,255,255,0.55); }
  .footer-bottom a:hover { color: #fff; }

  @media (max-width: 900px) {
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
    .footer-brand { grid-column: 1 / -1; }
  }

  @media (max-width: 560px) {
    .footer-grid { grid-template-columns: 1fr; }
    .footer-bottom { flex-direction: column; }
  }
</style>
