import Footer from "../../components/layout/Footer.astro";
import Realisations from "../../components/sections/Realisations.astro";
import ChatbotWidget from "../../components/chatbot/ChatbotWidget.astro";

const lang = "fr";
---

<BaseLayout
  lang={lang}
  title="Nos réalisations — ThinkTech Solutions"
  description="Découvrez les plateformes Moodle conçues et déployées par ThinkTech Solutions au Cameroun et en Afrique centrale : Bouka Creativ' Learning, ThinkTech Academy et Erfolg Zentrum."
>
  <Header lang={lang} />
