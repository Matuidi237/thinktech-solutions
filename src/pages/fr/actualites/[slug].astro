---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/layout/Header.astro";
import Footer from "../../../components/layout/Footer.astro";
import ChatbotWidget from "../../../components/chatbot/ChatbotWidget.astro";

export const prerender = true;

export async function getStaticPaths() {
  const articles = await getCollection("articles", ({ data }) => data.lang === "fr");
  return articles.map((article) => ({
    params: { slug: article.slug.replace(/^fr\//, "") },
    props: { article }
  }));
}

const { article } = Astro.props;
const { Content } = await article.render();

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: article.data.title,
  description: article.data.description,
  datePublished: article.data.publishDate.toISOString(),
  image: article.data.image ? `https://thinktech-solutions.com${article.data.image}` : "https://thinktech-solutions.com/images/og-cover.jpg",
  author: { "@type": "Organization", name: "ThinkTech Solutions", url: "https://thinktech-solutions.com" },
  publisher: { "@type": "Organization", name: "ThinkTech Solutions", logo: { "@type": "ImageObject", url: "https://thinktech-solutions.com/images/brand/logo-white.png" } },
  inLanguage: "fr-FR",
  url: `https://thinktech-solutions.com/fr/actualites/${article.slug.replace(/^fr\//, "")}`
};

const gradients: Record<string, string> = {
  "Conseils": "linear-gradient(135deg, #022179, #A42593)",
  "Sécurité": "linear-gradient(135deg, #0B0E2E, #022179)",
  "Étude de cas": "linear-gradient(135deg, #A42593, #C94BB0)",
};
const fallbackGradient = "linear-gradient(135deg, #022179, #A42593)";
const cover = article.data.image ? `background-image:url(${article.data.image})` : `background-image:${gradients[article.data.category ?? ""] ?? fallbackGradient}`;
---

<BaseLayout lang="fr" title={`${article.data.title} — ThinkTech Solutions`} description={article.data.description}>
  <Header lang="fr" />
  <main id="main-content">
    <section class="article-hero" style={cover}>
      <div class="container article-hero-inner reveal">
        <a href="/fr/actualites" class="back-link">← Toutes les actualités</a>
        {article.data.category && <span class="article-tag">{article.data.category}</span>}
        <h1>{article.data.title}</h1>
        <time>{article.data.publishDate.toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })}</time>
      </div>
    </section>

    <article class="container article-content reveal">
      <div class="article-body">
        <Content />
      </div>

      <div class="article-cta">
        <p>Envie d'échanger sur votre propre projet de formation en ligne ?</p>
        <a href="/fr/contact" class="btn btn-primary">Demander une démo</a>
      </div>
    </article>
  </main>
  <Footer lang="fr" />
  <ChatbotWidget lang="fr" />
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
</BaseLayout>

<style>
  .article-hero {
    position: relative;
    background-size: cover;
    background-position: center;
    padding: 5rem 0 3.5rem;
    color: #fff;
  }
  .article-hero::before { content: ""; position: absolute; inset: 0; background: rgba(11, 14, 46, 0.55); backdrop-filter: blur(3px); -webkit-backdrop-filter: blur(3px); }
  .article-hero-inner { position: relative; z-index: 1; max-width: 720px; }
  .article-hero h1 { color: #fff; margin: 0.75rem 0 0.5rem; }
  .article-hero time { color: rgba(255, 255, 255, 0.85); font-size: 0.9rem; }
  .back-link { display: inline-block; color: #fff; opacity: 0.85; font-size: 0.9rem; margin-bottom: 1rem; }
  .back-link:hover { opacity: 1; text-decoration: underline; }
  .article-tag {
    display: inline-block;
    background: rgba(255, 255, 255, 0.95);
    color: var(--color-primary);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    margin-bottom: 0.75rem;
  }

  .article-content { max-width: 720px; padding: 3rem 1.25rem 4rem; }
  .article-body { line-height: 1.85; font-size: 1.05rem; }
  .article-body :global(h2) { margin: 2.25rem 0 1rem; font-size: 1.5rem; }
  .article-body :global(p) { margin-bottom: 1.1rem; }
  .article-body :global(ul), .article-body :global(ol) { margin: 0 0 1.1rem 1.25rem; }
  .article-body :global(li) { margin-bottom: 0.4rem; }
  .article-body :global(blockquote) {
    margin: 1.75rem 0;
    padding: 1rem 1.5rem;
    border-left: 3px solid var(--color-accent);
    background: var(--color-bg-secondary);
    font-style: italic;
    border-radius: 0 8px 8px 0;
  }
  .article-body :global(a) { color: var(--color-accent); text-decoration: underline; }
  .article-body :global(hr) { border: none; border-top: 1px solid var(--color-border); margin: 2rem 0; }

  .article-cta {
    margin-top: 3rem;
    padding: 2rem;
    text-align: center;
    border-radius: 14px;
    background: var(--color-bg-secondary);
  }
  .article-cta p { margin-bottom: 1rem; font-weight: 500; color: var(--color-text); }

  @media (max-width: 700px) {
    .article-hero { padding: 3.5rem 0 2.5rem; }
  }
</style>
